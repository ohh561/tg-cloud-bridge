# Telegram Bot（从 @BotFather 获取 / Get from @BotFather）
BOT_TOKEN=your_bot_token_here

# 你的 Telegram User ID（从 @userinfobot 获取 / Get from @userinfobot）
ALLOWED_USER_ID=your_telegram_user_id

# Telegram API 凭据（从 my.telegram.org 获取 / Get from my.telegram.org）
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# AList / OpenList WebDAV 地址
ALIST_WEBDAV_CRYPT=http://openlist:5244/dav/PrivateVideo/
ALIST_WEBDAV_DIRECT=http://openlist:5244/dav/Onedrive/

# AList API 地址（用于文件夹浏览和分享链接）
ALIST_API_URL=http://openlist:5244

# AList 用户名和密码
ALIST_USER=admin
ALIST_PASS=password

# 可选：公网地址（用于生成下载链接）
# PUBLIC_URL=https://openlist.example.com
